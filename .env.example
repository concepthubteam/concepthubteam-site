# ╔══════════════════════════════════════════════════════════════╗
# ║  GOZI — Environment Variables                              ║
# ║  Copiați în .env și completați valorile reale              ║
# ╚══════════════════════════════════════════════════════════════╝
#
# Găsiți toate cheile în: Supabase Dashboard > Settings > API
# și Supabase Dashboard > Settings > Database

# ──────────────────────────────────────────────────────────────
# SUPABASE — React Native app (Expo)
# ──────────────────────────────────────────────────────────────

# URL-ul proiectului (Project URL)
# Ex: https://abcdefghij.supabase.co
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co

# Anon/public key — folosit în app (safe to expose, dar nu în .env.example)
# Settings > API > Project API keys > anon/public
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_PUBLIC_KEY

# ──────────────────────────────────────────────────────────────
# SUPABASE — Backend / Scrapers (NU în app!)
# ──────────────────────────────────────────────────────────────

# Service role key — bypass RLS, DOAR pentru scrapers/backend
# Settings > API > Project API keys > service_role
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# ──────────────────────────────────────────────────────────────
# SUPABASE — Conexiune directă PostgreSQL (pentru run_sql.py)
# ──────────────────────────────────────────────────────────────

# Parolă bază de date
# Settings > Database > Connection string > Password
SUPABASE_DB_PASSWORD=YOUR_DB_PASSWORD

# User PostgreSQL (format: postgres.YOUR_PROJECT_REF)
# Settings > Database > Connection string > User
SUPABASE_DB_USER=postgres.YOUR_PROJECT_REF

# Host pooler (implicit: aws-0-eu-central-1.pooler.supabase.com)
# SUPABASE_DB_HOST=aws-0-eu-central-1.pooler.supabase.com

# ──────────────────────────────────────────────────────────────
# TIKTOK — Apify Actor (tiktok_collector.py)
# ──────────────────────────────────────────────────────────────

# Token Apify pentru clockworks~tiktok-scraper
# https://console.apify.com/account/integrations
APIFY_API_TOKEN=YOUR_APIFY_API_TOKEN

# ──────────────────────────────────────────────────────────────
# VENUE DISCOVERY ENGINE (opțional)
# ──────────────────────────────────────────────────────────────

# Google Custom Search Engine (cel mai precis)
# https://developers.google.com/custom-search/v1/overview
# GOOGLE_CSE_API_KEY=YOUR_GOOGLE_CSE_API_KEY
# GOOGLE_CSE_ID=YOUR_GOOGLE_CSE_ID

# SerpAPI (fallback)
# https://serpapi.com/dashboard
# SERPAPI_KEY=YOUR_SERPAPI_KEY

# ──────────────────────────────────────────────────────────────
# NOTE: DuckDuckGo fallback nu necesită cheie — funcționează automat
# NOTE: Dacă nu setați cheile de mai sus, venue discovery folosește DuckDuckGo
# ──────────────────────────────────────────────────────────────
